## Dyslibria does not require an .env file for normal Docker use.
## These are optional overrides for source installs, reverse proxies, or custom ports.

MAIN_PORT=3000
WEBDAV_PORT=1900
BASE_URL=http://localhost:3000
# Optional:
# IMAGE_TAG=latest
# ALLOW_SERVER_RESTART=false
# SESSION_SECRET=replace-with-a-long-random-string
# MAX_UPLOAD_BYTES=104857600
# MAX_EPUB_ARCHIVE_ENTRIES=5000
# MAX_EPUB_EXTRACT_BYTES=314572800
